// This file defines all the tables in our database
// Prisma reads this and creates the actual PostgreSQL tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------- ENUMS (fixed list of allowed values) -------

// The 3 user roles
enum Role {
  ADMIN
  PM
  DEVELOPER
}

// Task can be in one of these states
enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  OVERDUE
}

// How important is the task
enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ------- TABLES -------

// Users table - stores all users (admin, pm, developers)
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // will be hashed, never stored as plain text
  role      Role     @default(DEVELOPER)
  createdAt DateTime @default(now())

  // One user can manage many projects (if they are a PM)
  managedProjects Project[] @relation("PMProjects")

  // One user can be assigned many tasks (if they are a Developer)
  assignedTasks Task[] @relation("AssignedTasks")

  // One user can have many activity log entries
  activityLogs ActivityLog[]

  // One user can have many notifications
  notifications Notification[]

  // One user can have many refresh tokens
  refreshTokens RefreshToken[]
}

// Clients table - the company's clients (customers)
model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  // One client can have many projects
  projects Project[]
}

// Projects table
model Project {
  id          String   @id @default(uuid())
  name        String
  description String? // ? means optional
  createdAt   DateTime @default(now())

  // Which client this project belongs to
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // Which PM manages this project
  pmId String
  pm   User   @relation("PMProjects", fields: [pmId], references: [id])

  // One project has many tasks
  tasks Task[]

  // One project has many activity logs
  activityLogs ActivityLog[]

  // Index on pmId because we often search "all projects for this PM"
  @@index([pmId])
}

// Tasks table
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  isOverdue   Boolean    @default(false)
  createdAt   DateTime   @default(now())

  // Which project this task belongs to
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  // Which developer is assigned to this task (optional)
  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  // Each task has an activity log (history of changes)
  activityLogs ActivityLog[]

  // Indexes: we often filter tasks by these columns
  @@index([projectId])
  @@index([assignedToId])
  @@index([status])
}

// ActivityLog table - records every status change on tasks
model ActivityLog {
  id          String   @id @default(uuid())
  description String // e.g. "Ravi moved Task #12 from In Progress → In Review"
  createdAt   DateTime @default(now())

  // Who made the change
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Which task was changed
  taskId String
  task   Task   @relation(fields: [taskId], references: [id])

  // Which project (stored here so we can filter by project easily)
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  // Indexes for fast filtering
  @@index([projectId])
  @@index([userId])
  @@index([taskId])
}

// Notifications table - in-app alerts for users
model Notification {
  id        String   @id @default(uuid())
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Which user gets this notification
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

// RefreshToken table - stores JWT refresh tokens
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Which user this token belongs to
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}
