# Database - replace 'postgres123' if you used a different password
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/velozity_db"

# Secret key for signing login tokens - can be any random string
JWT_SECRET="velozity_super_secret_jwt_key_2024"

# Secret key for refresh tokens - use a different string from JWT_SECRET
REFRESH_TOKEN_SECRET="velozity_refresh_secret_key_2024"

# Server port
PORT=5000
